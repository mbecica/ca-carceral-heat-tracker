# Cloudflare Pages headers.
# Live data changes on each pipeline commit — keep it briefly cached but revalidated.
/data/*
  Cache-Control: public, max-age=300, must-revalidate

# Assets are cache-busted via a ?v=<content-hash> query string (see the
# cht-asset partial), so a URL's bytes never change: cache hard and skip
# revalidation. A content change ships a new URL, picked up immediately.
/js/*
  Cache-Control: public, max-age=31536000, immutable
/css/*
  Cache-Control: public, max-age=31536000, immutable
